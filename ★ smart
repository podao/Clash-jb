# 流量嗅探
sniffer:
  enable: true
  sniff:
    HTTP:
      ports: [80, 8080-8880]
      override-destination: true
    TLS:
      ports: [443, 8443]
    QUIC:
      ports: [443, 8443]
  skip-domain:
    - "Mijia Cloud"
    - "+.push.apple.com"

# TUN模式配置
tun:
  enable: false
  stack: mixed
  dns-hijack:
    - "any:53"
    - "tcp://any:53"
  auto-route: true
  auto-redirect: true
  auto-detect-interface: true

hosts:
  miwifi.com: 192.168.31.2
  services.googleapis.cn: services.googleapis.com
  cn.bing.com: global.bing.com
  dns.alidns.com: [223.5.5.5, 223.6.6.6, 2400:3200::1, 2400:3200:baba::1]
  doh.pub: [1.12.12.12, 1.12.12.21, 120.53.53.53]
  dns.google: [8.8.8.8, 8.8.4.4, 2001:4860:4860::8888, 2001:4860:4860::8844]
  cloudflare-dns.com: [1.1.1.1, 1.0.0.1, 2606:4700:4700::1111, 2606:4700:4700::1001]
    
# DNS配置
dns:
  enable: true
  ipv6: false          # 建议关闭：国内移动网络 IPv6 往往不稳定，关闭后网页首屏开启更快
  use-hosts: true
  enhanced-mode: fake-ip
  listen: 0.0.0.0:1053
  respect-rules: true
  prefer-h3: true      # 开启 H3 加速加密查询
  
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter:
    - "geosite:cn"      # 核心：国内域名不走 Fake-IP，直接由系统解析，秒开且省电
    - "rule-set:direct"
    - "geosite:private"
    - "geosite:apple-cn"
    - "+.msftconnecttest.com"
    - "+.msftncsi.com"
    - "pool.ntp.org"
    - "*.lan"
    - "*.local"
    - "localsend.org"     # 文件传输
    - "+.localsend.org"

  # 基础 DNS：仅用于解析 DoH 的域名，必须是纯 IP
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29

  # 代理服务器解析：防止节点域名解析不出导致“节点超时”
  proxy-server-nameserver:
    - https://dns.alidns.com/dns-query
    - https://doh.pub/dns-query

  # 直连域名解析：命中 DIRECT 规则的走这里
  direct-nameserver:
    - https://dns.alidns.com/dns-query
    - https://doh.pub/dns-query

  # 默认解析：未命中以上规则的（通常是代理域名）走这里
  nameserver:
    - https://dns.google/dns-query
    - https://dns.cloudflare.com/dns-query

  nameserver-policy:
    "geosite:cn":
      - https://dns.alidns.com/dns-query
      - https://doh.pub/dns-query

    "domain-suffix:openai.com":
      - https://1.1.1.1/dns-query
      - https://8.8.8.8/dns-query
    "domain-suffix:chatgpt.com":
      - https://1.1.1.1/dns-query
      - https://8.8.8.8/dns-query
    "domain-suffix:auth0.com":
      - https://1.1.1.1/dns-query
      - https://8.8.8.8/dns-query
    "domain-suffix:oaistatic.com":
      - https://1.1.1.1/dns-query
      - https://8.8.8.8/dns-query
    "domain-suffix:oaiusercontent.com":
      - https://1.1.1.1/dns-query
      - https://8.8.8.8/dns-query


